....................     
.................... //////////////////////////////////////////////////////////////////////////////// 
.................... // 
.................... // can_set_mode() 
.................... // can2_set_mode() 
.................... // 
.................... // This function first sets the three bits (reqop2:reqop0) to the mode given  
.................... // through the argument. 
.................... // 
.................... // The reqop bits do not immediately change the mode of operation, the 
.................... // opmode bits in the C1CTRL1 or C2CTRL1 register (opmode2:opmode0) must change  
.................... // to reflect the actual change in mode, therefore a while statement is  
.................... // used to check if the C1CTRL1 or C2CTRL1 opmode bits have changed to reflect  
.................... // the change in mode. 
.................... // 
.................... //////////////////////////////////////////////////////////////////////////////// 
.................... void can_set_mode(CAN_OP_MODE mode) { 
*
006E4:  MOV     W5,[W15++]
....................    C1CTRL1.reqop=mode; 
006E6:  MOV     #FFF8,W0
006E8:  AND.B   401
006EA:  MOV.B   1040,W0L
006EC:  AND     #7,W0
006EE:  IOR.B   401
....................    while( (C1CTRL1.opmode) != mode ); 
006F0:  MOV.B   400,W0L
006F2:  LSR     W0,#5,W4
006F4:  AND     #7,W4
006F6:  MOV.B   W4L,W0L
006F8:  CP.B    1040
006FA:  BRA     NZ,6F0
006FC:  MOV     [--W15],W5
006FE:  RETURN  
.................... } 
....................  
.................... #if getenv("SFR_VALID:C2CTRL1") 
....................    void can2_set_mode(CAN_OP_MODE mode) { 
*
00B80:  MOV     W5,[W15++]
....................       C2CTRL1.reqop=mode; 
00B82:  MOV     #FFF8,W0
00B84:  AND.B   501
00B86:  MOV.B   1040,W0L
00B88:  AND     #7,W0
00B8A:  IOR.B   501
....................       while( (C2CTRL1.opmode) != mode ); 
00B8C:  MOV.B   500,W0L
00B8E:  LSR     W0,#5,W4
00B90:  AND     #7,W4
00B92:  MOV.B   W4L,W0L
00B94:  CP.B    1040
00B96:  BRA     NZ,B8C
00B98:  MOV     [--W15],W5
00B9A:  RETURN  
....................    } 
.................... #endif 
....................     
.................... //////////////////////////////////////////////////////////////////////////////// 
.................... // 
.................... // can_set_id() 
.................... // can2_set_id() 
.................... // 
.................... // Configures the xxxxEID and xxxxSID registers to configure the defined  
.................... // acceptance filter or acceptance filter mask to the specified ID 
.................... // 
.................... //   Parameters: 
.................... //     addr - pointer to first byte of ID register, starting with xxxxEID. 
.................... //            For example, a pointer to C1RXF0 
.................... // 
.................... //     id - ID to set filter or mask to 
.................... //     ext - Set to TRUE if this filter or mask uses an extended ID,  
.................... //     FALSE if not 
.................... // 
.................... //////////////////////////////////////////////////////////////////////////////// 
.................... void can_set_id(uint16_t *addr, uint32_t id, int1 ext)  
*
0080A:  MOV     W5,[W15++]
0080C:  MOV     W6,[W15++]
.................... { 
....................    uint16_t temp; 
....................    curmode=C1CTRL1.opmode; 
0080E:  MOV.B   400,W0L
00810:  LSR     W0,#5,W4
00812:  AND     #7,W4
00814:  PUSH    1000
00816:  MOV.B   W4L,[W15-#2]
00818:  POP     1000
....................  
....................    can_set_mode(CAN_OP_CONFIG); 
0081A:  MOV.B   #4,W0L
0081C:  MOV.B   W0L,1040
0081E:  CALL    6E4
....................     
....................    C1CTRL1.win=1; 
00822:  BSET.B  400.0
....................     
....................    if (ext) {  //extended 
00824:  CP0.B   103C
00826:  BRA     Z,86E
....................       //eid 
....................       *addr=(id & 0xffff);                         //0:15 
00828:  MOV     1036,W5
0082A:  CLR     W1
0082C:  MOV     1038,W0
0082E:  MOV     W0,[W5]
....................     
....................       //sid 
....................       addr-=1; 
00830:  MOV     1036,W4
00832:  SUB     W4,#2,W0
00834:  MOV     W0,1036
....................       *addr&=0x1C; 
00836:  MOV     1036,W5
00838:  MOV     [W5],W0
0083A:  AND     W0,#1C,W0
0083C:  MOV     W0,[W5]

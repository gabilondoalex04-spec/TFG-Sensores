.................... unsigned int8 normalizacionSuspen(unsigned int16 lmed, unsigned int16 data){ 
013AC:  CLR     103A
013AE:  CLR     103C
....................    int16  desplazamiento = 0, valornormal=0; 
....................    desplazamiento = data - lmed; 
013B0:  MOV     1038,W4
013B2:  MOV     1036,W3
013B4:  SUB     W4,W3,W0
013B6:  MOV     W0,103A
....................     
....................   // sacamos como un valor absoluto de lo que se desplaza 
....................    
....................    if (desplazamiento < -150) { //aqui es que ha cruzado del 45 al 0 
013B8:  MOV     103A,W4
013BA:  MOV     #FF6A,W3
013BC:  CP      W3,W4
013BE:  BRA     LE,13CC
....................     desplazamiento = desplazamiento + 255; 
013C0:  MOV     #FF,W4
013C2:  MOV     103A,W3
013C4:  ADD     W3,W4,W0
013C6:  MOV     W0,103A
....................      
....................       } 
013C8:  GOTO    13DA
....................    else if (desplazamiento > 150) {//aqui hemos cruzado del 0 al 45 (0 a 255) 
013CC:  MOV     103A,W4
013CE:  MOV     #96,W3
013D0:  CP      W3,W4
013D2:  BRA     GE,13DA
....................       desplazamiento = desplazamiento - 255; 
013D4:  MOV     103A,W4
013D6:  SUB     #FF,W4
013D8:  MOV     W4,103A
....................       } 
....................    valornormal = 128 + desplazamiento; 
013DA:  MOV     #80,W0
013DC:  ADD     103A,W0
013DE:  MOV     W0,103C
....................    if (valornormal < 0) valornormal = 0; 
013E0:  MOV     103C,W4
013E2:  CP      W4,#0
013E4:  BRA     GE,13E8
013E6:  CLR     103C
....................    if (valornormal > 255) valornormal = 255; 
013E8:  MOV     103C,W4
013EA:  MOV     #FF,W3
013EC:  CP      W3,W4
013EE:  BRA     GE,13F4
013F0:  MOV     #FF,W4
013F2:  MOV     W4,103C
....................    return valornormal; 
013F4:  MOV.B   103C,W0L
013F6:  MOV.B   W0L,0
013F8:  RETURN  
....................  } 

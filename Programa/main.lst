00BAC:  MOV.B   W4L,W0L
00BAE:  MOV.B   W0L,510
....................     
....................       C2CFG2.prseg=CAN2_BRG_PROPAGATION_TIME; 
00BB0:  MOV     512,W4
00BB2:  AND     #3F8,W4
00BB4:  IOR     #0,W4
00BB6:  MOV.B   W4L,W0L
00BB8:  MOV.B   W0L,512
....................       C2CFG2.seg1ph=CAN2_BRG_PHASE_SEGMENT_1; 
00BBA:  MOV     512,W4
00BBC:  AND     #3C7,W4
00BBE:  IOR     #20,W4
00BC0:  MOV.B   W4L,W0L
00BC2:  MOV.B   W0L,512
....................       C2CFG2.sam=CAN2_BRG_SAM; 
00BC4:  BCLR.B  512.6
....................       C2CFG2.seg2phts=CAN2_BRG_SEG_2_PHASE_TS; 
00BC6:  BSET.B  512.7
....................       C2CFG2.seg2ph=CAN2_BRG_PHASE_SEGMENT_2; 

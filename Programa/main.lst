.................... //////////////////////////////////////////////////////////////////////////////// 
.................... // 
.................... // can_set_baud() 
.................... // can2_set_baud() 
.................... // 
.................... // Configures the baud rate control registers.  All the defines here 
.................... // are defaulted in the can-PIC24.h file.  These defaults can, and 
.................... // probably should, be overwritten in the main code. 
.................... // 
.................... // Current defaults are set for 62.5 kBits if the PIC is running at 20 MHz. 
.................... // 
.................... //////////////////////////////////////////////////////////////////////////////// 
.................... void can_set_baud(void) { 
....................    C1CFG1.brp=CAN_BRG_PRESCALAR; 
*
00700:  MOV     410,W4
00702:  AND     #3C0,W4
00704:  IOR     #1,W4
00706:  MOV.B   W4L,W0L
00708:  MOV.B   W0L,410
....................    C1CFG1.sjw=CAN_BRG_SYNCH_JUMP_WIDTH; 
0070A:  MOV     410,W4
0070C:  AND     #33F,W4
0070E:  IOR     #0,W4
00710:  MOV.B   W4L,W0L
00712:  MOV.B   W0L,410
....................  
....................    C1CFG2.prseg=CAN_BRG_PROPAGATION_TIME; 
00714:  MOV     412,W4
00716:  AND     #3F8,W4
00718:  IOR     #0,W4
0071A:  MOV.B   W4L,W0L
0071C:  MOV.B   W0L,412
....................    C1CFG2.seg1ph=CAN_BRG_PHASE_SEGMENT_1; 
0071E:  MOV     412,W4
00720:  AND     #3C7,W4
00722:  IOR     #20,W4
00724:  MOV.B   W4L,W0L
00726:  MOV.B   W0L,412
....................    C1CFG2.sam=CAN_BRG_SAM; 
00728:  BCLR.B  412.6
....................    C1CFG2.seg2phts=CAN_BRG_SEG_2_PHASE_TS; 
0072A:  BSET.B  412.7
....................    C1CFG2.seg2ph=CAN_BRG_PHASE_SEGMENT_2; 
0072C:  MOV     412,W4
0072E:  LSR     W4,#8,W4
00730:  AND     #3F8,W4
00732:  IOR     #2,W4
00734:  MOV.B   W4L,W0L
00736:  MOV.B   W0L,413
....................    C1CFG2.wakfil=CAN_BRG_WAKE_FILTER; 
00738:  BCLR.B  413.6
0073A:  RETURN  
.................... } 
....................  

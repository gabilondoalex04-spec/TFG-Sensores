....................  
.................... // ECAN FIF0 Control Register 
.................... struct CiFCTRL_struct { 
....................    int fsa:5;              //0:4    // FIFO Area Starts with Buffer bits 
....................    int void12_5:8;         //5:12 
....................    int dmabs:3;            //13:15  // DMA Buffer Size bits 
.................... }; 
....................  
.................... struct CiFCTRL_struct C1FCTRL; 
.................... #word C1FCTRL=getenv("SFR:C1FCTRL") 

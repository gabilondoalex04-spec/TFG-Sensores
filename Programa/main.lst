.................... //////////////////////////////////////////////////////////////////////////////// 
.................... // 
.................... // can_enable_interrupts() 
.................... // can2_enable_interrupts() 
.................... // 
.................... //    Selects which interrupts causes the #INT_CAN1 and #INT_CAN2 interrupts to  
.................... //    fire 
.................... // 
.................... //    Parameters 
.................... //       setting - the selected interrupts  
.................... //          enumerated as 
.................... //             TB - Transmit Buffer Interrupt 
.................... //             RB - Receive Buffer Interrupt 
.................... //             RXOV - Receive Buffer Overflow Interrupt 
.................... //             FIFO - FIFO Almost Full Interrupt 
.................... //             ERR - Error interrupt 
.................... //             WAK - Wake-Up Interrupt 
.................... //             IVR - Invalid Message Received Interrupt 
.................... // 
.................... //          You can or these together (via |) to enable more than interrupt 
.................... // 
.................... //////////////////////////////////////////////////////////////////////////////// 
.................... void can_enable_interrupts(INTERRUPT setting) 
*
00200:  MOV     W5,[W15++]
.................... { 
....................    uint16_t temp; 
....................    uint16_t *ptr; 
....................     
....................    ptr = &C1INTE; 
00202:  MOV     #40C,W4
00204:  MOV     W4,105E
....................     
....................   // temp=C1INTE; 
....................   // C1INTE=(temp | setting); 
....................    
....................   temp = *ptr; 
00206:  MOV     105E,W0
00208:  MOV     [W0],[W15++]
0020A:  POP     105C
....................   *ptr = (temp | setting); 
0020C:  MOV     105E,W5
0020E:  MOV.B   105A,W0L
00210:  CLR.B   1
00212:  IOR     105C,W0
00214:  MOV     W0,[W5]
00216:  MOV     [--W15],W5
00218:  RETURN  
.................... } 
....................  
.................... #if getenv("SFR_VALID:C2CTRL1") 
....................    void can2_enable_interrupts(INTERRUPT setting) 
0021A:  MOV     W5,[W15++]
....................    { 
....................       uint16_t temp; 
....................       uint16_t *ptr; 
....................        
....................       ptr = &C2INTE; 
0021C:  MOV     #50C,W4
0021E:  MOV     W4,105E
....................        
....................       //temp=C2INTE; 
....................       //C2INTE=(temp | setting); 
....................       temp = *ptr; 
00220:  MOV     105E,W0
00222:  MOV     [W0],[W15++]
00224:  POP     105C
....................       *ptr = (temp | setting); 
00226:  MOV     105E,W5
00228:  MOV.B   105A,W0L

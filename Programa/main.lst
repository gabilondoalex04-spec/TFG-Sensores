....................  
.................... // ECAN Interrupt Code Register 
.................... struct CiVEC_struct { 
....................    int icode:7;            //0:6    // Interrupt Flag Code bits 
....................    int1 void7;             //7 
....................    int filhit:5;           //8:12   // Filter Hit Number bits 
....................    int void15_13:3;        //13:15 
.................... }; 

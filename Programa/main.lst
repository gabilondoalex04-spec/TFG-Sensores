....................          C1RXFUL2.rxful18=0; 
....................          break; 
....................       case 19: 
....................          C1RXFUL2.rxful19=0; 
....................          break; 
....................       case 20: 
....................          C1RXFUL2.rxful20=0; 
....................          break; 

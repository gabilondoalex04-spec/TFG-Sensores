....................    ptr=&ecan1_message_buffer[stat.buffer][0]; 
....................    stat.ext=(*ptr & 0x1); 
....................    temp=(*ptr & 0x1); 
....................       
....................    ptr+=2; 
....................    len=(*ptr & 0xF); 
....................    stat.rtr=((make8(*ptr,1) & 0x2) >> 1); 
....................     
....................    ptr+=5; 

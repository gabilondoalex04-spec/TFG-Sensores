....................      (getenv("DEVICE") == "PIC24EP512GP806") || (getenv("DEVICE") == "PIC24EP512GU810") || (getenv("DEVICE") == "PIC24EP512GU814") || \ 
....................      (getenv("DEVICE") == "DSPIC33EP256MU806") || (getenv("DEVICE") == "DSPIC33EP256MU810") || (getenv("DEVICE") == "DSPIC33EP256MU814") || \ 
....................      (getenv("DEVICE") == "DSPIC33EP512GP806") || (getenv("DEVICE") == "DSPIC33EP512MC806") || (getenv("DEVICE") == "DSPIC33EP512MU810") || (getenv("DEVICE") == "DSPIC33EP512MU814") 
....................   #define CAN_CANCKS 1        //For these PIC24EP and dsPIC33EP chips this bit is backwards 
....................                               //(1 sets FCCAN = FOSC/2 and 0 sets FCCAN = FOSC). 
....................  #else 
....................   #define CAN_CANCKS 0        //For PIC24EP and dsPIC33EP chips, 0 - FCCAN = FOSC/2 and 1 - FCCAN = FOSC 
....................  #endif                       //Bit not used for PIC24HJ and dsPIC33FJ chip, FCCAN = FOSC/2 
.................... #endif 
....................        
.................... #ifndef CAN2_CANCKS 
....................  #if (getenv("DEVICE") == "PIC24EP256GU810") || (getenv("DEVICE") == "PIC24EP256GU814") || \ 
....................      (getenv("DEVICE") == "PIC24EP512GP806") || (getenv("DEVICE") == "PIC24EP512GU810") || (getenv("DEVICE") == "PIC24EP512GU814") || \ 
....................      (getenv("DEVICE") == "DSPIC33EP256MU806") || (getenv("DEVICE") == "DSPIC33EP256MU810") || (getenv("DEVICE") == "DSPIC33EP256MU814") || \ 
....................      (getenv("DEVICE") == "DSPIC33EP512GP806") || (getenv("DEVICE") == "DSPIC33EP512MC806") || (getenv("DEVICE") == "DSPIC33EP512MU810") || (getenv("DEVICE") == "DSPIC33EP512MU814") 
....................   #define CAN2_CANCKS 1       //For these PIC24EP and dsPIC33EP chips this bit is backwards 
....................                               //(1 sets FCCAN = FOSC/2 and 0 sets FCCAN = FOSC). 
....................  #else 
....................   #define CAN2_CANCKS 0       //For PIC24EP and dsPIC33EP chips, 0 - FCCAN = FOSC/2 and 1 - FCCAN = FOSC 
....................  #endif                       //Bit not used for PIC24HJ and dsPIC33FJ chip, FCCAN = FOSC/2 
.................... #endif 

.................... //////////////////////////////////////////////////////////////////////////////// 
.................... // 
.................... // can_enable_filter() 
.................... // can2_enable_filter() 
.................... // 
.................... // Enables a given acceptance filter 
.................... // 
.................... // Parameters: 
.................... //      filter - the filter that is to be enabled 
.................... //         enumerated as - FLTEN0-FLTEN15 
.................... // 
.................... // Returns: 
.................... //    void 
.................... // 
.................... // More information can be found on Acceptance Filters in the PIC24H Family  
.................... // Reference Manual, Section 21 
.................... // 
.................... //////////////////////////////////////////////////////////////////////////////// 
.................... void can_enable_filter(CAN_FILTER_CONTROL filter) 
*
00A10:  MOV     W5,[W15++]
.................... { 
....................    uint16_t *ptr; 
....................  
....................    curmode=C1CTRL1.opmode; 
00A12:  MOV.B   400,W0L
00A14:  LSR     W0,#5,W4
00A16:  AND     #7,W4
00A18:  PUSH    1000
00A1A:  MOV.B   W4L,[W15-#2]
00A1C:  POP     1000
....................  
....................    can_set_mode(CAN_OP_CONFIG); 
00A1E:  MOV.B   #4,W0L
00A20:  MOV.B   W0L,1040
00A22:  CALL    6E4
....................  
....................    ptr = &C1FEN1; 
00A26:  MOV     #414,W4
00A28:  MOV     W4,1038
....................  
....................    *ptr|=filter; 
00A2A:  MOV     1038,W5
00A2C:  MOV     [W5],W0
00A2E:  IOR     1036,W0
00A30:  MOV     W0,[W5]
....................  
....................    can_set_mode(curmode); 
00A32:  MOV.B   1000,W0L
00A34:  MOV.B   W0L,1040
00A36:  CALL    6E4
00A3A:  MOV     [--W15],W5
00A3C:  RETURN  
.................... } 
....................  

.................... //////////////////////////////////////////////////////////////////////////////// 
.................... // 
.................... // can_set_buffer_id() 
.................... // can2_set_buffer_id() 
.................... // 
.................... // Configures the defined buffer to use the specified ID 
.................... // 
.................... // Parameters: 
.................... //       buffer - the desired buffer 
.................... //        enumerated as TRB0-TRB7 
.................... // 
.................... //       id - ID to set buffer to 
.................... //       ext - Set to TRUE is this buffer uses an extended ID, False if not 
.................... // 
.................... //////////////////////////////////////////////////////////////////////////////// 
.................... void can_set_buffer_id(BUFFER buffer, uint32_t id, int1 ext) 
.................... { 
....................    uint16_t *ptr; 
....................    uint16_t temp; 
....................     
....................    ptr=&ecan1_message_buffer[buffer][2]; 
....................  
....................    if (ext) 
....................    { 
....................       //eid 
....................       *ptr&=0x20F; 
....................       temp=((id & 0x3F) << 10); 
....................       *ptr|=temp; 
....................       ptr-=1; 
....................       temp=((id & 0x3FFC0) >> 6); 
....................       *ptr=temp; 
....................        
....................       //sid 
....................       ptr-=1; 
....................       *ptr&=0x2; 
....................       temp=(((id & 0x1FFC0000) >> 16) | ext); 
....................       *ptr|=temp; 
....................    } 
....................    else 
....................    { 
....................       //eid 
....................       *ptr&=0x20F; 
....................       ptr-=1; 
....................       *ptr=0; 
....................       
....................       //sid 
....................       ptr-=1; 
....................       *ptr&=0x2; 
....................       temp=(((id & 0x7FF) << 2) | ext); 
....................       *ptr|=temp; 
....................    } 
.................... } 
....................  
.................... #if getenv("SFR_VALID:C2CTRL1") 
....................    void can2_set_buffer_id(BUFFER buffer, uint32_t id, int1 ext) 
....................    { 
....................       uint16_t *ptr; 
....................       uint16_t temp; 
....................        
....................       ptr=&ecan2_message_buffer[buffer][2]; 
....................     
....................       if (ext) 
....................       { 
....................          //eid 
....................          *ptr&=0x20F; 
....................          temp=((id & 0x3F) << 10); 
....................          *ptr|=temp; 
....................          ptr-=1; 
....................          temp=((id & 0x3FFC0) >> 6); 
....................          *ptr=temp; 
....................           
....................          //sid 
....................          ptr-=1; 
....................          *ptr&=0x2; 
....................          temp=(((id & 0x1FFC0000) >> 16) | ext); 
....................          *ptr|=temp; 
....................       } 
....................       else 
....................       { 
....................          //eid 
....................          *ptr&=0x20F; 
....................          ptr-=1; 
....................          *ptr=0; 
....................          
....................          //sid 
....................          ptr-=1; 
....................          *ptr&=0x2; 
....................          temp=(((id & 0x7FF) << 2) | ext); 
....................          *ptr|=temp; 
....................       } 
....................    } 
.................... #endif 
....................  
.................... //////////////////////////////////////////////////////////////////////////////// 
.................... // 
.................... // can_set_buffer_size() 
.................... // can2_set_buffer_size() 
.................... // 
.................... // Configures the number of DMA buffers the ECAN module uses. 
.................... // 
.................... // Parameters: 
.................... //       size - the desired buffer size to be used. Valid sizes 4, 6, 8, 12, 16, 
.................... //              24, and 32 
.................... // 
.................... // Returns: 
.................... //       void 
.................... // 
.................... //////////////////////////////////////////////////////////////////////////////// 
.................... void can_set_buffer_size(uint8_t size) 
.................... { 
....................    if (size==4) 
*
0073C:  MOV     1036,W4
0073E:  CP.B    W4L,#4
00740:  BRA     NZ,752
....................       C1FCTRL.dmabs=0; 
00742:  MOV     406,W4
00744:  LSR     W4,#8,W4
00746:  AND     #31F,W4
00748:  IOR     #0,W4
0074A:  MOV.B   W4L,W0L
0074C:  MOV.B   W0L,407
0074E:  GOTO    7CC
....................    else if (size==6) 
00752:  MOV     1036,W4
00754:  CP.B    W4L,#6
00756:  BRA     NZ,768
....................       C1FCTRL.dmabs=1; 
00758:  MOV     406,W4
0075A:  LSR     W4,#8,W4
0075C:  AND     #31F,W4
0075E:  IOR     #20,W4
00760:  MOV.B   W4L,W0L
00762:  MOV.B   W0L,407
00764:  GOTO    7CC
....................    else if (size==8) 
00768:  MOV     1036,W4
0076A:  CP.B    W4L,#8
0076C:  BRA     NZ,77E
....................       C1FCTRL.dmabs=2; 
0076E:  MOV     406,W4
00770:  LSR     W4,#8,W4
00772:  AND     #31F,W4
00774:  IOR     #40,W4
00776:  MOV.B   W4L,W0L
00778:  MOV.B   W0L,407
0077A:  GOTO    7CC
....................    else if (size==12) 
0077E:  MOV     1036,W4
00780:  CP.B    W4L,#C
00782:  BRA     NZ,794
....................       C1FCTRL.dmabs=3; 
00784:  MOV     406,W4
00786:  LSR     W4,#8,W4
00788:  AND     #31F,W4
0078A:  IOR     #60,W4
0078C:  MOV.B   W4L,W0L
0078E:  MOV.B   W0L,407
00790:  GOTO    7CC
....................    else if (size==16) 
00794:  MOV     1036,W4
00796:  CP.B    W4L,#10
00798:  BRA     NZ,7AA
....................       C1FCTRL.dmabs=4; 
0079A:  MOV     406,W4
0079C:  LSR     W4,#8,W4
0079E:  AND     #31F,W4
007A0:  IOR     #80,W4
007A2:  MOV.B   W4L,W0L
007A4:  MOV.B   W0L,407
007A6:  GOTO    7CC
....................    else if (size==24) 
007AA:  MOV     1036,W4
007AC:  CP.B    W4L,#18
007AE:  BRA     NZ,7C0
....................       C1FCTRL.dmabs=5; 
007B0:  MOV     406,W4
007B2:  LSR     W4,#8,W4
007B4:  AND     #31F,W4
007B6:  IOR     #A0,W4
007B8:  MOV.B   W4L,W0L
007BA:  MOV.B   W0L,407
007BC:  GOTO    7CC
....................    else 
....................       C1FCTRL.dmabs=6; 
007C0:  MOV     406,W4
007C2:  LSR     W4,#8,W4
007C4:  AND     #31F,W4
007C6:  IOR     #C0,W4
007C8:  MOV.B   W4L,W0L
007CA:  MOV.B   W0L,407
007CC:  RETURN  
.................... } 

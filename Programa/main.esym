d G "MULTICHANNEL_MODE" 2 992 "0x0000"
d G "I2S_MODE" 2 993 "0x0001"
d G "AC97_16BIT_MODE" 2 994 "0x0002"
d G "AC97_20BIT_MODE" 2 995 "0x0003"
d G "JUSTIFY_DATA" 2 997 "0x0020" "Start data transmission on the same clock cycle as COFS pulses (multichannel)"
d G "MULTI_DEVICE_BUS" 2 998 "0x0040" "Tri-states the CSDO pin during unused time slots, normally drives '0'"
d G "UNDERFLOW_LAST" 2 1000 "0x0080" "Transmits the last written value to the dci when data underflow occurs. Default is undeflow silence."
d G "UNDERFLOW_SILENCE" 2 1001 "0x0000" "Transmit '0's on data undeflow. This will cause a clicking noise if you are underflowing data while outputing to a codec."
d G "DCI_SLAVE" 2 1003 "0x0100" "Default is master"
d G "DCI_MASTER" 2 1004 "0x0000"
d G "SAMPLE_FALLING_EDGE" 2 1006 "0x0000" "Default is Sample on the rising edge of the clock"
d G "SAMPLE_RISING_EDGE" 2 1007 "0x0200"
d G "DCI_CLOCK_INPUT" 2 1009 "0x0400" "SCLK is an input (supplied by codec or external source)"
d G "DCI_CLOCK_OUTPUT" 2 1010 "0x0000" "Default is clock output"
d G "ENABLE_LOOPBACK" 2 1012 "0x0800" "Connect the CSDI/CSDO internally; loops all of the sound back onto the bus"
d G "CODEC_MULTICHANNEL" 2 1014 "0x0000" "enables multichannel (generic) codec support"
d G "CODEC_I2S" 2 1015 "0x0001" "enables the I2S protocol"
d G "CODEC_AC16" 2 1016 "0x0002" "enables the AC-16 protocol, setupCodecTransmission has no effect"
d G "CODEC_AC20" 2 1017 "0x0003" "enables the AC-20 protocol, setupCodecTransmission has no effect"
d G "BUS_MASTER" 2 1019 "0x0000" "designates this device as the bus master"
d G "BUS_SLAVE" 2 1020 "0x0300" "designates this device as a slave on a bus controlled by another codec"
d G "TRISTATE_BUS" 2 1022 "0x0040" "when in master mode, the module will be in high impedance"
d G "SYNC_COFS_DATA_PULSE" 2 1024 "0x0020" "signifies that data starts transmitting on the same SCK pulse as the edge of the COFS pulse"
d G "SAMPLE_RISING" 2 1027 "0x0200" "sample data on the rising edge of the clock"
d G "SAMPLE_FALLING" 2 1028 "0x0000" "sample data on the falling edge of the clock"
